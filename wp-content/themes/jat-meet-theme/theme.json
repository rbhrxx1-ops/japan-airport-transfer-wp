{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "custom": false,
      "palette": [
        { "slug": "navy-950", "name": "濃紺", "color": "#081B33" },
        { "slug": "navy-800", "name": "紺", "color": "#153A5B" },
        { "slug": "gold-500", "name": "シャンパンゴールド", "color": "#C7A45A" },
        { "slug": "gold-100", "name": "淡いゴールド", "color": "#F4ECDD" },
        { "slug": "ivory", "name": "アイボリー", "color": "#FBF9F4" },
        { "slug": "white", "name": "白", "color": "#FFFFFF" },
        { "slug": "slate-700", "name": "本文", "color": "#334155" },
        { "slug": "slate-500", "name": "補助文", "color": "#64748B" },
        { "slug": "slate-200", "name": "境界線", "color": "#E2E8F0" },
        { "slug": "success", "name": "完了", "color": "#166534" },
        { "slug": "warning", "name": "注意", "color": "#9A5B13" },
        { "slug": "error", "name": "エラー", "color": "#B42318" }
      ]
    },
    "spacing": {
      "blockGap": true,
      "padding": true,
      "margin": true,
      "units": ["px", "rem", "%", "vw", "vh"],
      "spacingSizes": [
        { "slug": "2-xs", "name": "2XS", "size": "0.375rem" },
        { "slug": "xs", "name": "XS", "size": "0.625rem" },
        { "slug": "sm", "name": "S", "size": "1rem" },
        { "slug": "md", "name": "M", "size": "1.5rem" },
        { "slug": "lg", "name": "L", "size": "2.5rem" },
        { "slug": "xl", "name": "XL", "size": "4rem" },
        { "slug": "2-xl", "name": "2XL", "size": "6rem" }
      ]
    },
    "typography": {
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "sans-jp",
          "name": "日本語ゴシック",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'YuGothic', 'Noto Sans JP', 'Segoe UI', sans-serif"
        },
        {
          "slug": "serif-jp",
          "name": "日本語明朝",
          "fontFamily": "'Hiragino Mincho ProN', 'Yu Mincho', 'YuMincho', 'Noto Serif JP', Georgia, serif"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "name": "小", "size": "0.8125rem" },
        { "slug": "sm", "name": "補助", "size": "0.9375rem" },
        { "slug": "md", "name": "本文", "size": "1rem" },
        { "slug": "lg", "name": "大", "size": "1.25rem" },
        { "slug": "xl", "name": "見出し3", "size": "clamp(1.5rem, 2.2vw, 2rem)" },
        { "slug": "2-xl", "name": "見出し2", "size": "clamp(2rem, 4vw, 3.25rem)" },
        { "slug": "hero", "name": "主見出し", "size": "clamp(2.625rem, 6vw, 5.5rem)" }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "soft", "name": "ソフト", "shadow": "0 18px 50px rgba(8, 27, 51, 0.10)" },
        { "slug": "lift", "name": "リフト", "shadow": "0 24px 64px rgba(8, 27, 51, 0.16)" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|ivory",
      "text": "var:preset|color|slate-700"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "padding": {
        "left": "clamp(1rem, 4vw, 2rem)",
        "right": "clamp(1rem, 4vw, 2rem)"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|sans-jp",
      "fontSize": "var:preset|font-size|md",
      "fontWeight": "500",
      "lineHeight": "1.85"
    },
    "elements": {
      "button": {
        "border": { "radius": "999px" },
        "color": {
          "background": "var:preset|color|gold-500",
          "text": "var:preset|color|navy-950"
        },
        "spacing": {
          "padding": {
            "top": "0.85rem",
            "right": "1.5rem",
            "bottom": "0.85rem",
            "left": "1.5rem"
          }
        },
        "typography": {
          "fontSize": "0.9375rem",
          "fontWeight": "700"
        }
      },
      "heading": {
        "color": { "text": "var:preset|color|navy-950" },
        "typography": {
          "fontWeight": "700",
          "letterSpacing": "-0.02em",
          "lineHeight": "1.35"
        }
      },
      "link": {
        "color": { "text": "var:preset|color|navy-800" },
        "typography": { "textDecoration": "none" }
      }
    },
    "blocks": {
      "core/button": {
        "variations": {
          "outline": {
            "border": { "color": "var:preset|color|navy-800", "width": "1px" },
            "color": { "text": "var:preset|color|navy-800" }
          }
        }
      },
      "core/image": {
        "border": { "radius": "24px" }
      },
      "core/navigation": {
        "typography": { "fontSize": "0.875rem", "fontWeight": "700" }
      },
      "core/quote": {
        "border": { "color": "var:preset|color|gold-500", "width": "0 0 0 3px" },
        "spacing": { "padding": { "left": "1.5rem" } }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "ヘッダー", "area": "header" },
    { "name": "footer", "title": "フッター", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page-wide", "title": "ワイドページ", "postTypes": ["page"] },
    { "name": "page-reservation", "title": "お申し込みページ", "postTypes": ["page"] }
  ]
}
